{
  "name": "@vocdoni/app-sdk",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "Vocdoni App SDK monorepo",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "turbo run build && vitest run --config integration/vitest.config.ts",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev": "turbo run dev --parallel",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vocdoni/api-client": "workspace:*",
    "@vocdoni/api-types": "workspace:*",
    "@vocdoni/api-voting": "workspace:*",
    "jsdom": "^26.0.0",
    "msw": "^2.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0"
  },

  "engines": {
    "node": ">= 20"
  },
  "packageManager": "pnpm@11.7.0"
}
